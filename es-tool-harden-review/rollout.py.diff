+# ---- Delimiter-Contract (escaping-frei) ------------------------------------------------
+# Statt strikt-JSON (dessen Quote-Escaping auf langem/zitatreichem HTML reproduzierbar reisst,
+# z. B. pid 142) liefert das Modell jedes Feld zwischen Markern als ROHES HTML — kein Escaping noetig.
+END_MARK  = "<<<END>>>"
+_FIELD_RE = re.compile(r"<<<FIELD:(\w+)>>>")
+
+def _fields_to_markers(fields):
+    """Eingabe-Felder ins Marker-Format serialisieren (symmetrisch zur erwarteten Modell-Ausgabe)."""
+    out = []
+    for k, v in fields.items():
+        out.append("<<<FIELD:%s>>>" % k)
+        out.append(v if v is not None else "")
+    out.append(END_MARK)
+    return "\n".join(out)
+
+def _parse_delimited(txt, expected_keys):
+    """Marker-Ausgabe -> OrderedDict. Inhalt je Feld bis zum naechsten <<<FIELD:/<<<END>>>, getrimmt.
+    Fehlt <<<END>>>, fehlt jeder Marker oder ein erwartetes Feld -> ValueError (greift bestehenden Retry)."""
+    if END_MARK not in txt:
+        raise ValueError("Marker <<<END>>> fehlt")
+    body = txt.split(END_MARK, 1)[0]
+    matches = list(_FIELD_RE.finditer(body))
+    if not matches:
+        raise ValueError("kein <<<FIELD:...>>>-Marker gefunden")
+    out = OrderedDict()
+    for i, m in enumerate(matches):
+        start = m.end()
+        end = matches[i + 1].start() if i + 1 < len(matches) else len(body)
+        out[m.group(1)] = body[start:end].strip()
+    missing = [k for k in expected_keys if k not in out]
+    if missing:
+        raise ValueError(f"erwartete Felder fehlen in der Ausgabe: {missing}")
+    return out
+
