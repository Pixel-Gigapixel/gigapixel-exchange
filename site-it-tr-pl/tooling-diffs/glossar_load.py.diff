+def translate_term(de_row, lang, guide):
+    """Uebersetzt die Textfelder eines DE-Term-Rows. faq_items wird strukturerhaltend uebersetzt
+    (q/a als Marker-Felder, JSON danach neu zusammengebaut). Slug = typo3-Segment des uebersetzten Titels."""
+    from collections import OrderedDict
+    fields = OrderedDict()
+    for k in ("title", "short_definition", "long_definition", "meta_description"):
+        v = (de_row.get(k) or "").strip()
+        if v:
+            fields[k] = v
+    faq = []
+    raw = (de_row.get("faq_items") or "").strip()
+    if raw and raw != "[]":
+        try:
+            faq = json.loads(raw)
+        except Exception:
+            faq = []
+    for i, item in enumerate(faq):
+        if (item.get("question") or "").strip():
+            fields[f"faq_q{i}"] = item["question"]
+        if (item.get("answer") or "").strip():
+            fields[f"faq_a{i}"] = item["answer"]
+
+    out = R.translate_fields(fields, guide, R.OLLAMA_MODEL, lang)
+
+    title = out.get("title", de_row.get("title") or "")
+    faq_out = []
+    for i, item in enumerate(faq):
+        faq_out.append({
+            "question": out.get(f"faq_q{i}", item.get("question", "")),
+            "answer":   out.get(f"faq_a{i}", item.get("answer", "")),
+        })
+    return {
+        "de_uid": str(de_row["uid"]),
+        "category": str(de_row["category"]),
+        "is_methodology_term": str(de_row["is_methodology_term"]),
+        "robots": de_row.get("robots") or "index,follow",
+        "title": title,
+        "slug": R.typo3_slug_segment(title),
+        "short_definition": out.get("short_definition", ""),
+        "long_definition": out.get("long_definition", ""),
+        "meta_description": out.get("meta_description", ""),
+        "faq_items": json.dumps(faq_out, ensure_ascii=False),
+        "_de": {k: (de_row.get(k) or "") for k in ("title", "short_definition", "long_definition", "meta_description")},
+        "_lang": lang,
+    }
+
+
+def translate_cats(de_cats, lang, guide):
+    """Uebersetzt die 7 Kategorie-Titel in EINEM Call. Liefert {de_uid: {'title','slug','sorting','pid'}}."""
+    from collections import OrderedDict
+    fields = OrderedDict()
+    for cu, src in de_cats.items():
+        fields[f"cat_{cu}"] = src["title"]
+    out = R.translate_fields(fields, guide, R.OLLAMA_MODEL, lang)
+    res = {}
+    for cu, src in de_cats.items():
+        title = out.get(f"cat_{cu}", src["title"])
+        res[cu] = {"title": title, "slug": R.typo3_slug_segment(title), "sorting": src["sorting"], "pid": src["pid"]}
+    return res
+
