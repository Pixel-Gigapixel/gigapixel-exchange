<?xml version="1.0" encoding="UTF-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
  <file source-language="de" target-language="fr" datatype="plaintext"
        original="EXT:gigapixels_visualsearch/Resources/Private/Language/locallang.xlf">
    <header/>
    <body>

      <!-- SearchBar -->
      <trans-unit id="search.placeholder"><source>Bilder suchen…</source><target>Rechercher des images…</target></trans-unit>
      <trans-unit id="search.btn.camera"><source>Bildsuche öffnen</source><target>Ouvrir la recherche par image</target></trans-unit>
      <trans-unit id="search.btn.submit"><source>Suchen</source><target>Rechercher</target></trans-unit>

      <!-- ExpandedPanel -->
      <trans-unit id="drop.prompt"><source>Bild hierher ziehen oder</source><target>Déposez une image ici ou</target></trans-unit>
      <trans-unit id="drop.prompt.click"><source>klicken</source><target>cliquez</target></trans-unit>
      <trans-unit id="drop.hint"><source>JPEG · PNG · WebP · max 10 MB</source><target>JPEG · PNG · WebP · max 10 Mo</target></trans-unit>
      <trans-unit id="options.summary"><source>Optionen</source><target>Options</target></trans-unit>
      <trans-unit id="slider.weight.label"><source>Bild / Text</source><target>Image / Texte</target></trans-unit>
      <trans-unit id="slider.weight.title"><source>Wie stark soll das Bild gegenüber dem Text gewichtet werden?</source><target>Dans quelle mesure l'image doit-elle être pondérée par rapport au texte ?</target></trans-unit>
      <trans-unit id="slider.weight.left"><source>◀ Text</source><target>◀ Texte</target></trans-unit>
      <trans-unit id="slider.weight.right"><source>Bild ▶</source><target>Image ▶</target></trans-unit>
      <trans-unit id="slider.weight.image"><source>Bild</source><target>Image</target></trans-unit>
      <trans-unit id="slider.weight.text"><source>Text</source><target>Texte</target></trans-unit>
      <trans-unit id="slider.threshold.label"><source>Min. Ähnlichkeit</source><target>Sim. min.</target></trans-unit>
      <trans-unit id="slider.threshold.title"><source>Skala 0.50–0.90 — Embeddings erreichen praktisch nie 1.00</source><target>Échelle 0,50–0,90 — les embeddings n'atteignent pratiquement jamais 1,00</target></trans-unit>

      <!-- Results -->
      <trans-unit id="btn.remove_image"><source>Bild entfernen</source><target>Supprimer l'image</target></trans-unit>
      <trans-unit id="summary.results"><source>%1$s Treffer · %2$s ms</source><target>%1$s résultat(s) · %2$s ms</target></trans-unit>
      <trans-unit id="summary.no_results"><source>Keine Ergebnisse · %1$s ms</source><target>Aucun résultat · %1$s ms</target></trans-unit>
      <trans-unit id="sort.label"><source>Sortierung:</source><target>Tri :</target></trans-unit>
      <trans-unit id="sort.size"><source>Größe</source><target>Taille</target></trans-unit>
      <trans-unit id="sort.width"><source>Breite</source><target>Largeur</target></trans-unit>
      <trans-unit id="sort.height"><source>Höhe</source><target>Hauteur</target></trans-unit>
      <trans-unit id="sort.price"><source>Preis</source><target>Prix</target></trans-unit>
      <trans-unit id="sort.reset"><source>✕ Relevanz</source><target>✕ Pertinence</target></trans-unit>
      <trans-unit id="limited.title"><source>Begrenzte Treffer-Anzeige.</source><target>Affichage limité des résultats.</target></trans-unit>
      <trans-unit id="limited.body"><source>Die besten %1$s Treffer für „%2$s" werden angezeigt — weitere Bilder hatten zu niedrige Übereinstimmung und werden ausgeblendet.</source><target>Les %1$s meilleurs résultats pour « %2$s » sont affichés — d'autres images avaient une correspondance trop faible et sont masquées.</target></trans-unit>
      <trans-unit id="no_results.title"><source>Kein Ergebnis</source><target>Aucun résultat</target></trans-unit>
      <trans-unit id="no_results.body"><source>Zur Suchanfrage wurden keine Treffer gefunden — Schwelle reduzieren oder andere Stichworte / ein anderes Bild versuchen.</source><target>Aucun résultat trouvé — réduire le seuil ou essayer d'autres mots-clés / une autre image.</target></trans-unit>

      <!-- ResultCard -->
      <trans-unit id="card.no_thumb"><source>kein Bild</source><target>pas d'image</target></trans-unit>
      <trans-unit id="card.details"><source>Details</source><target>Détails</target></trans-unit>
      <trans-unit id="badge.combined.tooltip"><source>Gewichtete Gesamtnote – Bild- und Textübereinstimmung kombiniert nach Slider-Gewichtung</source><target>Score global pondéré – correspondance image et texte combinées selon la pondération du curseur</target></trans-unit>
      <trans-unit id="badge.image.tooltip"><source>Bildähnlichkeit zum hochgeladenen Bild (0–1)</source><target>Similarité visuelle avec l'image téléchargée (0–1)</target></trans-unit>
      <trans-unit id="badge.text.tooltip"><source>Textübereinstimmung mit KI-Beschreibung und Keywords (0–1)</source><target>Correspondance textuelle avec la description IA et les mots-clés (0–1)</target></trans-unit>
      <trans-unit id="badge.total.title"><source>Gewichtete Gesamtnote (Slider-basiert)</source><target>Score global pondéré (basé sur le curseur)</target></trans-unit>
      <trans-unit id="badge.total.label"><source>Gesamt</source><target>Total</target></trans-unit>
      <trans-unit id="badge.image.title"><source>Visuelle Ähnlichkeit (Cosine)</source><target>Similarité visuelle (Cosine)</target></trans-unit>
      <trans-unit id="badge.text.title"><source>Keyword-Relevanz</source><target>Pertinence des mots-clés</target></trans-unit>

      <!-- SimilarImages -->
      <trans-unit id="similar.title"><source>Ähnliche Bilder</source><target>Images similaires</target></trans-unit>

    </body>
  </file>
</xliff>
